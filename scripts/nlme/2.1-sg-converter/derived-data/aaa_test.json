  "modelText": "\r\n# [INPUT]\r\n  \r\n    ka = 0.5;\r\n    Vd = 3;\r\n    CL = 5;\r\n    Vp = 2;\r\n    Q = 6;\r\n\r\n# [MODEL]\r\n\r\n    ### Explicit functions\r\n    Cc = Ac/Vd;\r\n\r\n    ### Initial conditions\r\n    Ad(0) = 0;\r\n    Ac(0) = 0;\r\n    Ap(0) = 0;\r\n\r\n    ### Differential equations\r\n    d/dt(Ad) = - ka*Ad;\r\n    d/dt(Ac) = ka*Ad - CL*Cc - Q*(Ac/Vd - Ap/Vp);\r\n    d/dt(Ap) = Q*(Ac/Vd - Ap/Vp);\r\n"
